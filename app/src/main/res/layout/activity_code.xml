<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/editor_background_dark">

    <!-- Professional Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        app:title="Java Editor"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationContentDescription="Back" />

    <!-- Task Card (Əgər task varsa görünür) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/taskCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/task_card_bg"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/taskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Task"
                android:textColor="@color/task_title"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/taskDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/task_desc"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Code Editor Container -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/editor_panel_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:background="@color/editor_bg">

            <!-- Line Numbers -->
            <com.ali.utils.SyncScrollView
                android:id="@+id/lineNumbersScroll"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:background="@color/line_number_bg"
                android:scrollbars="none">

                <TextView
                    android:id="@+id/lineNumbers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="@color/line_number_text"
                    android:textSize="12sp"
                    android:typeface="monospace"
                    android:gravity="right"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingRight="8dp"
                    android:paddingLeft="4dp"
                    android:lineSpacingExtra="4dp" />
            </com.ali.utils.SyncScrollView>

            <!-- Code Input -->
            <ScrollView
                android:id="@+id/codeScrollView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scrollbars="vertical">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="horizontal">

                    <EditText
                        android:id="@+id/codeInput"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:hint="// Write your Java code here..."
                        android:textColorHint="@color/editor_hint"
                        android:textColor="@color/editor_text"
                        android:textSize="13sp"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:typeface="monospace"
                        android:background="@android:color/transparent"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:paddingLeft="12dp"
                        android:paddingRight="16dp"
                        android:gravity="top|left"
                        android:minWidth="800dp"
                        android:lineSpacingExtra="4dp" />
                </HorizontalScrollView>
            </ScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Auto-complete Suggestions -->
    <ListView
        android:id="@+id/suggestionsList"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@color/suggestion_bg"
        android:visibility="gone"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="4dp"
        android:divider="@color/suggestion_divider"
        android:dividerHeight="1dp" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/clearBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🗑️ Clear"
            android:textAllCaps="false"
            android:backgroundTint="@color/btn_clear"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/runBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="▶ Run Code"
            android:textAllCaps="false"
            android:backgroundTint="@color/btn_run"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- Output Console -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/outputContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/console_bg"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Console Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:background="@color/console_header_bg"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Console Output"
                    android:textColor="@color/console_header_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/clearOutputBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Clear"
                    android:textSize="11sp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:textColor="@color/console_btn" />

                <Button
                    android:id="@+id/hideOutputBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Hide"
                    android:textSize="11sp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:textColor="@color/console_btn" />
            </LinearLayout>

            <!-- Console Content -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/console_content_bg"
                android:padding="12dp"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/outputText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="> Ready to run Java code..."
                    android:textColor="@color/console_text"
                    android:textSize="12sp"
                    android:typeface="monospace"
                    android:lineSpacingExtra="2dp"
                    android:textIsSelectable="true" />
            </ScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Ad Container -->
    <LinearLayout
        android:id="@+id/adContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="4dp"
        android:background="@color/ad_bg">

        <com.google.android.gms.ads.AdView
            android:id="@+id/adJavaCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:adSize="BANNER"
            app:adUnitId="ca-app-pub-5367924704859976/8399396085" />
    </LinearLayout>
</LinearLayout>