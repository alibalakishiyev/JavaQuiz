<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="#263238">

    <!-- Başlıq -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#37474F"
        android:gravity="center_vertical">


        <!-- YENİ: Menyu Düyməsi (Üç nöqtə) -->
        <Button
            android:id="@+id/menuBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⋮"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_margin="4dp"
            android:padding="8dp"
            android:visibility="visible"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Python Editor"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:gravity="center"/>

        <LinearLayout
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/undoBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↩ Geri"
                android:backgroundTint="#FF9800"
                android:layout_margin="4dp"
                android:padding="8dp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:enabled="false" />

            <Button
                android:id="@+id/redoBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="↪ İrəli"
                android:backgroundTint="#4CAF50"
                android:layout_margin="4dp"
                android:padding="8dp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:enabled="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- Task Description -->
    <TextView
        android:id="@+id/taskDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Task Description"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:padding="12dp"
        android:background="#37474F"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <!-- Kod Editörü Alanı -->
    <LinearLayout
        android:id="@+id/codeEditorLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="horizontal"
        android:background="#1E282C"
        android:layout_marginBottom="8dp">

        <!-- Satır Numaraları -->
        <ScrollView
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:background="#263238"
            android:scrollbars="none">

            <TextView
                android:id="@+id/lineNumbers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="#546E7A"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:gravity="right"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:paddingRight="8dp"
                android:lineSpacingExtra="4dp"/>
        </ScrollView>

        <!-- Kod Editörü -->
        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="vertical|horizontal">

            <EditText
                android:id="@+id/codeInput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="# Python Code"
                android:textColorHint="#546E7A"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:inputType="textMultiLine|textNoSuggestions"
                android:fontFamily="monospace"
                android:background="@android:color/transparent"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:paddingLeft="8dp"
                android:paddingRight="16dp"
                android:gravity="top|left"
                android:minWidth="1000dp"
                android:lineSpacingExtra="4dp"
                android:breakStrategy="simple"
                android:autoSizeTextType="none"/>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Auto-complete Suggestions -->
    <ListView
        android:id="@+id/suggestionsList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.3"
        android:background="#37474F"
        android:visibility="gone"
        android:layout_marginBottom="4dp"/>

    <!-- Butonlar (Sadəcə Run və Bilmirəm qalır, digərləri menyuya köçürüldü) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/runBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▶ Run"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="#2196F3"
            android:padding="16dp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/dontKnowBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="❓ Bilmirəm"
            android:backgroundTint="#FF5722"
            android:layout_marginStart="4dp"
            android:padding="12dp"
            android:textColor="@android:color/white"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- KONSOL / Çıktı Alanı -->
    <LinearLayout
        android:id="@+id/outputContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5"
        android:orientation="vertical"
        android:background="#1E282C"
        android:visibility="visible"
        android:animateLayoutChanges="true">

        <!-- Konsol Başlıq -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#263238"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📟 Konsol Çıktısı"
                android:textColor="#78909C"
                android:textSize="12sp"
                android:textStyle="bold"
                android:padding="8dp"/>

            <Button
                android:id="@+id/copyOutputBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Kopyala"
                android:textColor="#64B5F6"
                android:textSize="11sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/clearOutputBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗑️ Təmizlə"
                android:textColor="#78909C"
                android:textSize="11sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/hideOutputBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="#78909C"
                android:textSize="14sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:layout_marginEnd="4dp"/>
        </LinearLayout>

        <!-- Konsol Mətn Sahəsi -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#1A1E22"
            android:padding="8dp"
            android:scrollbars="vertical">

            <TextView
                android:id="@+id/outputText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="> Proqramı işə salın..."
                android:textColor="#E0E0E0"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:background="@android:color/transparent"
                android:padding="12dp"
                android:lineSpacingExtra="4dp"
                android:lineSpacingMultiplier="1.2"
                android:textIsSelectable="true"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:longClickable="true"
                android:linksClickable="false"
                android:cursorVisible="false"
                android:gravity="top|start"
                android:scrollbars="vertical"
                android:maxLines="500"
                android:scrollHorizontally="false"
                android:autoLink="none"/>
        </ScrollView>

        <!-- Reklam Container -->
        <LinearLayout
            android:id="@+id/adContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="4dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.gms.ads.AdView
                android:id="@+id/adPythoneCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                app:adSize="BANNER"
                app:adUnitId="ca-app-pub-5367924704859976/8399396085"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>