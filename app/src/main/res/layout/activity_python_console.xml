<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <!-- Professional Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2196F3"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        android:titleTextColor="@color/background" />

    <!-- Task Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/taskCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#2C3E50">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/taskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Task"
                android:textColor="#64B5F6"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/taskDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#B0BEC5"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Code Editor Container -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:background="#1E1E1E">

            <!-- Line Numbers - Custom SyncScrollView -->
            <com.ali.utils.SyncScrollView
                android:id="@+id/lineNumbersScroll"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:background="#252526"
                android:scrollbars="none">

                <TextView
                    android:id="@+id/lineNumbers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="#6A6A6A"
                    android:textSize="13sp"
                    android:typeface="monospace"
                    android:gravity="right"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingRight="8dp"
                    android:paddingLeft="4dp"
                    android:lineSpacingExtra="4dp" />
            </com.ali.utils.SyncScrollView>

            <!-- Code Input -->
            <ScrollView
                android:id="@+id/codeScrollView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scrollbars="vertical">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="horizontal">

                    <EditText
                        android:id="@+id/codeInput"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:hint="# Write your Python code here..."
                        android:textColorHint="#6A6A6A"
                        android:textColor="#D4D4D4"
                        android:textSize="13sp"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:typeface="monospace"
                        android:background="@android:color/transparent"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:paddingLeft="12dp"
                        android:paddingRight="16dp"
                        android:gravity="top|left"
                        android:minWidth="800dp"
                        android:lineSpacingExtra="4dp" />
                </HorizontalScrollView>
            </ScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <!-- Auto-complete Suggestions -->
    <ListView
        android:id="@+id/suggestionsList"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#252526"
        android:visibility="gone"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="4dp"
        android:divider="#3E3E3E"
        android:dividerHeight="1dp" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/runBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="▶ Run Code"
            android:textAllCaps="false"
            android:backgroundTint="#2196F3"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/dontKnowBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="❓ Need Help"
            android:textAllCaps="false"
            android:backgroundTint="#FF5722"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- Output Console -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/outputContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Console Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:background="#2C2C2C"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Console Output"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/copyOutputBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Copy"
                    android:textSize="11sp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:textColor="#64B5F6" />

                <Button
                    android:id="@+id/clearOutputBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Clear"
                    android:textSize="11sp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:textColor="#9E9E9E" />

                <Button
                    android:id="@+id/hideOutputBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Hide"
                    android:textSize="11sp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:textColor="#9E9E9E" />
            </LinearLayout>

            <!-- Console Content -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#1E1E1E"
                android:padding="12dp"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/outputText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="> Ready to run Python code..."
                    android:textColor="#A9B7C6"
                    android:textSize="12sp"
                    android:typeface="monospace"
                    android:lineSpacingExtra="2dp"
                    android:textIsSelectable="true" />
            </ScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Ad Container -->
    <LinearLayout
        android:id="@+id/adContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:gravity="center">

        <com.google.android.gms.ads.AdView
            android:id="@+id/adPythoneCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:adSize="BANNER"
            app:adUnitId="ca-app-pub-5367924704859976/8399396085" />
    </LinearLayout>
</LinearLayout>