  "training_guidelines": {
    "general": [
      "Use mixed precision (fp16/bf16) for 2x speedup and 50% memory reduction",
      "Enable gradient checkpointing for large models (30-50% memory saving)",
      "Use Flash Attention when available (2-4x faster, 30% memory saving)",
      "Monitor loss curves to detect overfitting/underfitting",
      "Use gradient accumulation for large effective batch sizes",
      "Implement early stopping based on validation loss",
      "Save checkpoints regularly during training"
    ],
    "NLP": [
      "Use AdamW optimizer with linear warmup + cosine decay schedule",
      "Typical batch sizes: 32-512, effective batch size: 256-4096",
      "Sequence length: 512-2048 for most tasks",
      "Use label smoothing (0.05-0.1) for better generalization"
    ],
    "Vision": [
      "Use SGD with momentum or AdamW with cosine annealing",
      "Data augmentation: RandomResizedCrop, HorizontalFlip, ColorJitter",
      "Label smoothing: 0.05-0.1",
      "MixUp and CutMix for better performance on small datasets"
    ],
    "TTS": [
      "Use L1 or Mel-Spectrogram loss for mel generation",
      "Phoneme-level alignment helps with long utterances",
      "Typical sample rate: 22050-24000 Hz",
      "Mel spectrogram parameters: n_mels=80, hop_length=256, win_length=1024"
    ],
    "ASR": [
      "Use CTC loss with blank token or Transducer loss",
      "SpecAugment for speech augmentation (time warping, frequency masking)",
      "Typical sample rate: 16000 Hz",
      "Context length: 2-20 seconds of audio"
    ]
  },

  "gpu_memory_estimation": {
    "formula": "params_in_billions * 4 * 1.2 + batch_size * seq_len * hidden_size * 4 / 1e9",
    "factors": {
      "optimizer_state": 2.0,
      "gradients": 1.0,
