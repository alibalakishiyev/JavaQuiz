  "type_specific_rules": {
    "NLP": {
      "model_architecture": {
        "n_head": {"base_formula": "round(log(data_size) * 1.5)", "minimum": 4, "maximum": 32, "step": 2},
        "n_layer": {"base_formula": "round(sqrt(data_size) / 1000)", "minimum": 6, "maximum": 48, "step": 2},
        "n_embd": {"base_formula": "round(n_layer * 64)", "minimum": 256, "maximum": 8192, "step": 64},
        "use_rotary": true,
        "bias": false,
        "attention_type": "flash",
        "norm_type": "LayerNorm"
      },
      "training_parameters": {
        "batch_size": {"base_formula": "8 * log(data_size + 1)", "minimum": 4, "maximum": 128, "step": 4},
        "block_size": 1024,
        "learning_rate": {"base": 6e-5, "max": 1e-3, "min": 1e-6},
        "warmup_steps": {"base_formula": "round(max_iters * 0.1)", "minimum": 100, "maximum": 5000},
        "weight_decay": 0.01,
        "gradient_clipping": 1.0,
        "precision": "fp16"
      }
    },
    "TTS": {
      "model_architecture": {
        "n_head": {"base_formula": "round(log(data_size) * 1.2)", "minimum": 2, "maximum": 16, "step": 2},
        "n_layer": {"base_formula": "round(sqrt(data_size) / 1500)", "minimum": 4, "maximum": 24, "step": 2},
        "n_embd": {"base_formula": "round(n_layer * 64)", "minimum": 192, "maximum": 4096, "step": 64},
        "use_rotary": false,
        "bias": true,
        "attention_type": "mha",
        "norm_type": "LayerNorm"
      },
      "training_parameters": {
        "batch_size": {"base_formula": "4 * log(data_size + 1)", "minimum": 2, "maximum": 64, "step": 2},
        "block_size": 512,
        "learning_rate": {"base": 2e-4, "max": 5e-4, "min": 1e-6},
        "warmup_steps": {"base_formula": "round(max_iters * 0.05)", "minimum": 50, "maximum": 2000},
        "weight_decay": 0.001,
        "gradient_clipping": 0.5,
        "precision": "fp32"
      }
    },
    "ASR": {
      "model_architecture": {
        "n_head": {"base_formula": "round(log(data_size) * 1.4)", "minimum": 4, "maximum": 24, "step": 2},
        "n_layer": {"base_formula": "round(sqrt(data_size) / 1200)", "minimum": 6, "maximum": 32, "step": 2},
        "n_embd": {"base_formula": "round(n_layer * 64)", "minimum": 384, "maximum": 6144, "step": 64},
        "use_rotary": true,
        "bias": false,
        "attention_type": "flash",
        "norm_type": "LayerNorm"
      },
      "training_parameters": {
        "batch_size": {"base_formula": "6 * log(data_size + 1)", "minimum": 4, "maximum": 96, "step": 4},
        "block_size": 2048,
        "learning_rate": {"base": 1e-4, "max": 5e-4, "min": 1e-7},
        "warmup_steps": {"base_formula": "round(max_iters * 0.08)", "minimum": 100, "maximum": 3000},
        "weight_decay": 0.005,
        "gradient_clipping": 0.8,
        "precision": "fp16"
      }
    },
    "Vision": {
      "model_architecture": {
        "n_head": {"base_formula": "round(log(data_size) * 0.8)", "minimum": 2, "maximum": 16, "step": 2},
        "n_layer": {"base_formula": "round(sqrt(data_size) / 2000)", "minimum": 4, "maximum": 56, "step": 2},
        "n_embd": {"base_formula": "round(n_layer * 48)", "minimum": 128, "maximum": 4096, "step": 64},
        "use_rotary": false,
        "bias": true,
        "attention_type": "mha",
        "norm_type": "BatchNorm"
      },
      "training_parameters": {
        "batch_size": {"base_formula": "16 * log(data_size + 1)", "minimum": 8, "maximum": 256, "step": 8},
        "block_size": 256,
        "learning_rate": {"base": 1e-3, "max": 1e-2, "min": 1e-5},
        "warmup_steps": {"base_formula": "round(max_iters * 0.05)", "minimum": 50, "maximum": 1000},
        "weight_decay": 0.0001,
        "gradient_clipping": 2.0,
        "precision": "fp16"
      }
    },
    "Multimodal": {
      "model_architecture": {
        "n_head": {"base_formula": "round(log(data_size) * 1.6)", "minimum": 8, "maximum": 48, "step": 4},
        "n_layer": {"base_formula": "round(sqrt(data_size) / 800)", "minimum": 12, "maximum": 64, "step": 4},
        "n_embd": {"base_formula": "round(n_layer * 128)", "minimum": 512, "maximum": 16384, "step": 128},
        "use_rotary": true,
        "bias": false,
        "attention_type": "flash",
        "norm_type": "RMSNorm"
      },
      "training_parameters": {
        "batch_size": {"base_formula": "2 * log(data_size + 1)", "minimum": 2, "maximum": 32, "step": 2},
        "block_size": 4096,
        "learning_rate": {"base": 3e-5, "max": 2e-4, "min": 1e-7},
        "warmup_steps": {"base_formula": "round(max_iters * 0.15)", "minimum": 200, "maximum": 10000},
        "weight_decay": 0.02,
        "gradient_clipping": 0.5,
        "precision": "bf16"
      }
    },
    "Recommendation": {
      "model_architecture": {
        "n_head": {"base_formula": "round(log(data_size) * 1.0)", "minimum": 2, "maximum": 12, "step": 2},
        "n_layer": {"base_formula": "round(sqrt(data_size) / 3000)", "minimum": 3, "maximum": 12, "step": 1},
        "n_embd": {"base_formula": "round(n_layer * 64)", "minimum": 128, "maximum": 1024, "step": 32},
        "use_rotary": false,
        "bias": true,
        "attention_type": "mha",
        "norm_type": "LayerNorm"
      },
      "training_parameters": {
        "batch_size": {"base_formula": "32 * log(data_size + 1)", "minimum": 16, "maximum": 512, "step": 16},
        "block_size": 128,
        "learning_rate": {"base": 1e-3, "max": 5e-3, "min": 1e-5},
        "warmup_steps": {"base_formula": "round(max_iters * 0.1)", "minimum": 100, "maximum": 2000},
        "weight_decay": 0.00001,
        "gradient_clipping": 5.0,
        "precision": "fp32"
      }
    }
  },

  "common_parameters": {
    "n_embd": {
      "base_formula": "round(data_size / 10000) * 64",
      "minimum": 128,
      "maximum": 8192,
      "divisible_by": "n_head"
    },
    "learning_rate": {
      "base_formula": "6e-5 * (1 - log(data_size + 1) / 20)",
      "minimum": 1e-7,
      "maximum": 1e-2
    },
    "dropout": {
      "base_formula": "max(0.05, min(0.4, 0.2 - (data_size / 100000000)))"
    },
    "attention_dropout": {
      "base_formula": "dropout * 0.8",
      "minimum": 0.05,
      "maximum": 0.3
    },
    "residual_dropout": {
      "base_formula": "dropout * 0.5",
      "minimum": 0.0,
      "maximum": 0.2
    }
  },

