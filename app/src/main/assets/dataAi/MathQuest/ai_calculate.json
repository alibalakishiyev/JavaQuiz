  "optimizers": {
    "AdamW": {"default_lr": 1e-4, "weight_decay": 0.01, "betas": [0.9, 0.999]},
    "Adam": {"default_lr": 1e-4, "weight_decay": 0.0, "betas": [0.9, 0.999]},
    "SGD": {"default_lr": 0.01, "momentum": 0.9, "weight_decay": 0.0001},
    "LAMB": {"default_lr": 1e-3, "weight_decay": 0.01, "betas": [0.9, 0.999]},
    "Lion": {"default_lr": 1e-4, "weight_decay": 0.01},
    "Adafactor": {"default_lr": 1e-3, "weight_decay": 0.0},
    "RMSprop": {"default_lr": 1e-4, "alpha": 0.99, "momentum": 0.0}
  },

  "loss_functions": {
    "NLP": ["CrossEntropyLoss", "LabelSmoothingCrossEntropy", "CTCLoss", "MSELoss"],
    "Vision": ["CrossEntropyLoss", "FocalLoss", "DiceLoss", "MSELoss", "L1Loss"],
    "TTS": ["L1Loss", "MSELoss", "MelSpectrogramLoss", "STFTLoss", "MultiResolutionSTFTLoss"],
    "ASR": ["CTCLoss", "CrossEntropyLoss", "TransducerLoss"],
    "Multimodal": ["ContrastiveLoss", "InfoNCE", "TripletLoss"],
    "Recommendation": ["BCELoss", "MSELoss", "BPRLoss"]
  },

  "schedulers": {
    "CosineAnnealing": {"T_max": 100, "eta_min": 1e-6},
    "LinearWarmup": {"warmup_steps": 1000, "total_steps": 10000},
    "StepLR": {"step_size": 30, "gamma": 0.1},
    "ReduceLROnPlateau": {"factor": 0.5, "patience": 5},
    "OneCycleLR": {"max_lr": 1e-3, "total_steps": 10000},
    "CosineAnnealingWarmRestarts": {"T_0": 50, "T_mult": 2, "eta_min": 1e-6}
  },

  "hardware_profiles": {
    "T4": {"memory_gb": 16, "compute_capability": "7.5", "tf32": true},
    "V100": {"memory_gb": 32, "compute_capability": "7.0", "tf32": true},
    "A100": {"memory_gb": 40, "compute_capability": "8.0", "tf32": true, "bf16": true},
